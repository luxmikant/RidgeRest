# MongoDB
MONGODB_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=leaveSystem
MONGODB_DB_NAME=ridgerest
# Set to true ONLY for local dev on Windows if you hit TLS errors
MONGODB_TLS_ALLOW_INVALID_CERTIFICATES=false

# JWT
SECRET_KEY=change-me-to-a-random-32-byte-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=8

# CORS — set FRONTEND_URL to your Vercel domain in production
FRONTEND_URL=http://localhost:5173
EXTRA_CORS_ORIGINS=

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Datadog (optional)
ENABLE_DDTRACE=false
DD_SERVICE=ridgerest-api
DD_ENV=development
DD_VERSION=0.1.0
DD_PROFILING_ENABLED=false
DD_RUNTIME_METRICS_ENABLED=false
